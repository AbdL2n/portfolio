---
// Skills.astro
---

<section id="skills" class="py-24 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 left-0 w-72 h-72 rounded-full bg-sky-500/5 blur-3xl"></div>
    <div class="absolute bottom-1/4 right-0 w-96 h-96 rounded-full bg-indigo-500/5 blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="section-badge" data-i18n="skills_badge">Skills</span>
      <h2 class="text-4xl md:text-5xl font-bold mt-4 mb-4 gradient-text" data-i18n="skills_title">
        Technical Expertise
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="skills_subtitle">
        A broad skill set spanning cybersecurity, infrastructure, development, and more.
      </p>
    </div>

    <!-- Skills grid: 2 cols on md, 3 cols on lg -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Card 0 -->
      <div class="card skill-card reveal reveal-delay-1 group">
        <div class="skill-icon" data-i18n="skills_cat_0_icon">🔒</div>
        <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-sky-400 transition-colors duration-300" data-i18n="skills_cat_0_title">
          Security &amp; SOC
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="skills_cat_0_desc">
          Penetration Testing, SIEM, IAM, SOC, Honeypot, Firewalls, Kali Linux, CTF
        </p>
        <div class="skill-card-glow bg-sky-500/10"></div>
      </div>

      <!-- Card 1 -->
      <div class="card skill-card reveal reveal-delay-2 group">
        <div class="skill-icon" data-i18n="skills_cat_1_icon">🌐</div>
        <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-sky-400 transition-colors duration-300" data-i18n="skills_cat_1_title">
          Networks &amp; Infrastructure
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="skills_cat_1_desc">
          LAN/WAN, TCP/IP, VPN, VLANs, Cisco, Windows Server, Active Directory
        </p>
        <div class="skill-card-glow bg-indigo-500/10"></div>
      </div>

      <!-- Card 2 -->
      <div class="card skill-card reveal reveal-delay-3 group">
        <div class="skill-icon" data-i18n="skills_cat_2_icon">💻</div>
        <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-sky-400 transition-colors duration-300" data-i18n="skills_cat_2_title">
          Development
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="skills_cat_2_desc">
          Python, TypeScript, Java, Bash, SQL, C, Docker, Git, REST APIs
        </p>
        <div class="skill-card-glow bg-sky-500/10"></div>
      </div>

      <!-- Card 3 -->
      <div class="card skill-card reveal reveal-delay-1 group">
        <div class="skill-icon" data-i18n="skills_cat_3_icon">🖥️</div>
        <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-sky-400 transition-colors duration-300" data-i18n="skills_cat_3_title">
          Systems
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="skills_cat_3_desc">
          Linux (Debian, Kali, Ubuntu), Windows Server 2019, VMware, Hyper-V, SCADA
        </p>
        <div class="skill-card-glow bg-indigo-500/10"></div>
      </div>

      <!-- Card 4 -->
      <div class="card skill-card reveal reveal-delay-2 group">
        <div class="skill-icon" data-i18n="skills_cat_4_icon">🌍</div>
        <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-sky-400 transition-colors duration-300" data-i18n="skills_cat_4_title">
          Languages
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="skills_cat_4_desc">
          French — Native · English — Professional · Arabic — Native
        </p>
        <div class="skill-card-glow bg-sky-500/10"></div>
      </div>

      <!-- Card 5 -->
      <div class="card skill-card reveal reveal-delay-3 group">
        <div class="skill-icon" data-i18n="skills_cat_5_icon">🤝</div>
        <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-sky-400 transition-colors duration-300" data-i18n="skills_cat_5_title">
          Soft Skills
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed" data-i18n="skills_cat_5_desc">
          Project Management, Teaching, Problem-solving, Agile, Team leadership
        </p>
        <div class="skill-card-glow bg-indigo-500/10"></div>
      </div>

    </div>
  </div>
</section>

<style>
  .skill-card {
    position: relative;
    overflow: hidden;
    padding: 1.75rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .skill-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(56, 189, 248, 0.08);
  }

  .skill-icon {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    display: block;
    transition: transform 0.3s ease;
  }

  .skill-card:hover .skill-icon {
    transform: scale(1.1);
  }

  .skill-card-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .skill-card:hover .skill-card-glow {
    opacity: 1;
  }
</style>
