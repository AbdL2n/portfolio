---
// Education.astro

const baseUrl = import.meta.env.BASE_URL;

const schools = [
  {
    logo: "${baseUrl}images/logos/cytech.png",
    nameKey: "edu_school_0_name",
    nameDefault: "CY Tech — Cergy Paris Université",
    degreeKey: "edu_school_0_degree",
    degreeDefault: "Engineering Degree — CS &amp; Industrial",
    periodKey: "edu_school_0_period",
    periodDefault: "2022 – 2025",
    detailKey: "edu_school_0_detail",
    detailDefault: "Specialization in IT/OT, cybersecurity and development",
  },
  {
    logo: "${baseUrl}images/logos/howest.png",
    nameKey: "edu_school_1_name",
    nameDefault: "Howest — Bruges, Belgium",
    degreeKey: "edu_school_1_degree",
    degreeDefault: "University Exchange Semester",
    periodKey: "edu_school_1_period",
    periodDefault: "01/2024 – 06/2024",
    detailKey: "edu_school_1_detail",
    detailDefault: "Cybersecurity (pentest, cracking, mobile security) and app prototyping.",
  },
  {
    logo: "${baseUrl}images/logos/cpge.png",
    nameKey: "edu_school_2_name",
    nameDefault: "CPGE — Lycée Louis Thuillier",
    degreeKey: "edu_school_2_degree",
    degreeDefault: "Preparatory Classes (PCSI / PC★)",
    periodKey: "edu_school_2_period",
    periodDefault: "2020 – 2022",
    detailKey: "edu_school_2_detail",
    detailDefault: "Two years of Intensive training in maths, physics, engineering ( Bachelor degree).",
  },
  {
    logo: "${baseUrl}images/logos/lycee.png",
    nameKey: "edu_school_3_name",
    nameDefault: "Lycée J-B Delambre",
    degreeKey: "edu_school_3_degree",
    degreeDefault: "Scientific Bac — Highest Honours",
    periodKey: "edu_school_3_period",
    periodDefault: "2019",
    detailKey: "edu_school_3_detail",
    detailDefault: "Major: Mathematics &amp; Engineering Sciences.",
  },
];
---

<section id="education" class="py-24 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-0 w-80 h-80 rounded-full bg-sky-500/5 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-72 h-72 rounded-full bg-indigo-500/5 blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="section-badge" data-i18n="edu_badge">Education</span>
      <h2 class="text-4xl md:text-5xl font-bold mt-4 mb-4 gradient-text" data-i18n="edu_title">
        Academic Background
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="edu_subtitle">
        Rigorous academic training from preparatory classes to an engineering degree.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="edu-timeline-line"></div>

      <div class="space-y-12">
        {schools.map((school, idx) => (
          <div class={`relative flex gap-6 reveal reveal-delay-${Math.min(idx + 1, 4)}`}>
            <!-- Timeline dot -->
            <div class="edu-timeline-dot-wrapper">
              <div class="edu-timeline-dot"></div>
            </div>

            <!-- Logo -->
            <div class="flex-shrink-0 mt-1">
              <div class="logo-placeholder w-12 h-12 rounded-xl overflow-hidden">
                <img
                  src={baseUrl + school.logo}
                  alt=""
                  class="w-full h-full object-contain mix-blend-multiply"
                  style={school.logo.includes('howest') ? 'transform: scale(1.4);' : ''}
                  onerror="this.style.display='none'; this.parentElement.classList.add('logo-missing')"
                />
              </div>
            </div>

            <!-- Content -->
            <div class="card flex-1 p-6 hover:border-indigo-500/40 transition-colors duration-300">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                <div>
                  <h3
                    class="text-xl font-bold text-white"
                    data-i18n={school.nameKey}
                    set:html={school.nameDefault}
                  />
                  <p
                    class="text-indigo-400 font-medium mt-0.5"
                    data-i18n={school.degreeKey}
                    set:html={school.degreeDefault}
                  />
                </div>
                <span class="tag text-xs flex-shrink-0" data-i18n={school.periodKey}>
                  {school.periodDefault}
                </span>
              </div>
              <p
                class="text-slate-400 text-sm leading-relaxed"
                data-i18n={school.detailKey}
                set:html={school.detailDefault}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .edu-timeline-line {
    position: absolute;
    left: 4.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgb(129 140 248 / 0.3) 10%,
      rgb(56 189 248 / 0.3) 50%,
      rgb(129 140 248 / 0.3) 90%,
      transparent
    );
  }

  .edu-timeline-dot-wrapper {
    position: absolute;
    left: 4.1rem;
    top: 1.5rem;
    z-index: 10;
  }

  .edu-timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #818cf8, #38bdf8);
    box-shadow: 0 0 12px rgba(129, 140, 248, 0.6);
  }

  .logo-placeholder {
    background: #ffffff;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
  }

  .logo-placeholder.logo-missing::before {
    content: "?";
    color: rgb(129 140 248 / 0.4);
    font-size: 1.25rem;
    font-weight: bold;
  }
</style>
