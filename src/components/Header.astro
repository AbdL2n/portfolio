---
// src/components/Header.astro

const baseUrl = import.meta.env.BASE_URL;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(8,13,26,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(56,189,248,0.08);"
>
  <div class="max-w-6xl mx-auto px-5 md:px-8 h-16 flex items-center justify-between">

    <!-- ── Logo / Name ── -->
    <a
      href={baseUrl}
      class="font-bold text-lg text-slate-100 hover:text-sky-400 transition-colors duration-200 tracking-tight"
    >
      Portfolio<span class="text-sky-400">.</span>
    </a>

    <!-- ── Desktop Nav ── -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {[
        { key: "about",      href: "#about"      },
        { key: "experience", href: "#experience" },
        { key: "education",  href: "#education"  },
        { key: "projects",   href: "#projects"   },
        { key: "skills",     href: "#skills"     },
      ].map(({ key, href }) => (
        <a
          href={baseUrl + href}
          data-i18n={`nav_${key}`}
          class="nav-link px-3 py-1.5 text-sm text-slate-400 hover:text-sky-400 hover:bg-sky-400/5 rounded-md transition-all duration-200 font-medium"
        >
          {key.charAt(0).toUpperCase() + key.slice(1)}
        </a>
      ))}
    </nav>

    <!-- ── Right Side: Lang + Contact + CV ── -->
    <div class="hidden md:flex items-center gap-3">

      <!-- Language Switcher -->
      <div class="flex items-center gap-1 bg-navy-800/50 border border-sky-400/10 rounded-lg p-1">
        <button
          data-lang-btn="en"
          onclick="window.switchLang('en')"
          title="English"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold transition-all duration-200 hover:bg-sky-400/10 opacity-100"
          aria-label="Switch to English"
        >
          <span class="text-base">🇬🇧</span>
          <span class="text-slate-300">EN</span>
        </button>
        <div class="w-px h-4 bg-sky-400/20"></div>
        <button
          data-lang-btn="fr"
          onclick="window.switchLang('fr')"
          title="Français"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold transition-all duration-200 hover:bg-sky-400/10 opacity-40"
          aria-label="Passer en français"
        >
          <span class="text-base">🇫🇷</span>
          <span class="text-slate-300">FR</span>
        </button>
      </div>

      <!-- Contact link -->
      <a
        href={baseUrl + "/contact"}
        data-i18n="nav_contact"
        class="px-3 py-1.5 text-sm text-slate-400 hover:text-sky-400 hover:bg-sky-400/5 rounded-md transition-all duration-200 font-medium"
      >
        Contact
      </a>

      <!-- Download CV -->
      <a
        href={baseUrl + "/cv/Resume_Abd-Ennour_OUAALI.pdf"}
        download
        data-i18n="nav_downloadCV"
        class="btn-primary text-sm py-2 px-4"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download CV
      </a>
    </div>

    <!-- ── Mobile: Lang + Hamburger ── -->
    <div class="flex md:hidden items-center gap-3">
      <!-- Mobile lang switcher (compact) -->
      <div class="flex items-center gap-1">
        <button
          data-lang-btn="en"
          onclick="window.switchLang('en')"
          class="text-lg opacity-100 transition-opacity"
          aria-label="English"
        >🇬🇧</button>
        <button
          data-lang-btn="fr"
          onclick="window.switchLang('fr')"
          class="text-lg opacity-40 transition-opacity"
          aria-label="Français"
        >🇫🇷</button>
      </div>

      <!-- Hamburger button -->
      <button
        id="menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="flex flex-col justify-center items-center w-9 h-9 gap-1.5 rounded-md hover:bg-sky-400/10 transition-colors"
      >
        <span class="hamburger-bar block w-5 h-0.5 bg-slate-300 rounded transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-slate-300 rounded transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-slate-300 rounded transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- ── Mobile Menu Drawer ── -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    style="border-top: 1px solid rgba(56,189,248,0.08);"
  >
    <nav class="px-5 py-4 flex flex-col gap-1">
      {[
        { key: "about",      label: "About",      href: "#about"      },
        { key: "skills",     label: "Skills",     href: "#skills"     },
        { key: "experience", label: "Experience", href: "#experience" },
        { key: "education",  label: "Education",  href: "#education"  },
        { key: "projects",   label: "Projects",   href: "#projects"   },
      ].map(({ key, label, href }) => (
        <a
          href={baseUrl + href}
          data-i18n={`nav_${key}`}
          class="mobile-nav-link block px-3 py-2.5 text-sm text-slate-300 hover:text-sky-400 hover:bg-sky-400/5 rounded-md transition-all font-medium"
        >
          {label}
        </a>
      ))}
      <div class="mt-3 pt-3 border-t border-sky-400/10 flex flex-col gap-2">
        <a
          href={baseUrl + "/contact"}
          data-i18n="nav_contact"
          class="block px-3 py-2.5 text-sm text-slate-300 hover:text-sky-400 hover:bg-sky-400/5 rounded-md transition-all font-medium"
        >
          Contact
        </a>
        <a
          href={baseUrl + "/cv/Resume_Abd-Ennour_OUAALI.pdf"}
          download
          class="btn-primary text-sm py-2.5 px-4 justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          <span data-i18n="nav_downloadCV">Download CV</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  // ── Hamburger menu toggle ──
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const bars = document.querySelectorAll(".hamburger-bar");

  toggle?.addEventListener("click", () => {
    const isOpen = menu.style.maxHeight && menu.style.maxHeight !== "0px";
    if (isOpen) {
      menu.style.maxHeight = "0px";
      toggle.setAttribute("aria-expanded", "false");
      bars[0].style.transform = "";
      bars[1].style.opacity = "1";
      bars[2].style.transform = "";
    } else {
      menu.style.maxHeight = menu.scrollHeight + "px";
      toggle.setAttribute("aria-expanded", "true");
      bars[0].style.transform = "translateY(8px) rotate(45deg)";
      bars[1].style.opacity = "0";
      bars[2].style.transform = "translateY(-8px) rotate(-45deg)";
    }
  });

  // Close mobile menu on nav link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu.style.maxHeight = "0px";
      toggle.setAttribute("aria-expanded", "false");
      bars[0].style.transform = "";
      bars[1].style.opacity = "1";
      bars[2].style.transform = "";
    });
  });

  // ── Header scroll shadow ──
  const header = document.getElementById("header");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header.style.boxShadow = "0 4px 30px rgba(0,0,0,0.4)";
    } else {
      header.style.boxShadow = "none";
    }
  }, { passive: true });
</script>
