---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="border-t border-sky-400/10 bg-[#04080f] py-8">
  <div class="max-w-6xl mx-auto px-5 md:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">

      <!-- Left: Name / Brand -->
      <div class="text-center md:text-left">
        <span class="font-bold text-slate-300 text-lg">
          AO<span class="text-sky-400">.</span>
        </span>
        <p class="text-slate-600 text-xs mt-0.5">Abd-Ennour OUAALI</p>
      </div>

      <!-- Center: Made with -->
      <p class="text-slate-600 text-xs text-center">
        <span data-i18n="footer_madeWith">Made with ❤️ using</span>
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sky-400/70 hover:text-sky-400 transition-colors ml-1"
        >Astro</a>
        &amp;
        <a
          href="https://tailwindcss.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sky-400/70 hover:text-sky-400 transition-colors"
        >Tailwind</a>
      </p>

      <!-- Right: Copyright -->
      <p class="text-slate-600 text-xs text-center md:text-right">
        &copy; {year} Abd-Ennour OUAALI.
        <span data-i18n="footer_rights">All rights reserved.</span>
      </p>
    </div>
  </div>
</footer>
