---
// ContactSection.astro
---

<section id="contact" class="py-24 relative overflow-hidden">
  <!-- Gradient background overlay -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-sky-950/10 to-indigo-950/20"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-sky-500/8 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-72 h-72 rounded-full bg-indigo-500/8 blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-72 h-72 rounded-full bg-sky-500/6 blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <span class="section-badge" data-i18n="cta_badge">Contact</span>
      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-bold mt-4 mb-5 gradient-text leading-tight"
        data-i18n="cta_title"
      >
        Let's Work Together
      </h2>
      <p
        class="text-slate-400 text-lg max-w-xl mx-auto leading-relaxed"
        data-i18n="cta_subtitle"
      >
        Whether you have a project in mind or just want to connect, I'd love to hear from you.
      </p>
    </div>

    <!-- CTA Button -->
    <div class="flex justify-center mb-14 reveal reveal-delay-1">
      <a href="/contact" class="btn-primary cta-btn" data-i18n="cta_btn">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Go to contact page
      </a>
    </div>

    <!-- Contact info cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-12 reveal reveal-delay-2">

    <!-- Social links -->
    <div class="flex items-center justify-center gap-5 reveal reveal-delay-3">
      <!-- GitHub -->
      <a
        href="https://github.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="social-link"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span>GitHub</span>
      </a>

      <div class="social-divider"></div>

      <!-- LinkedIn -->
      <a
        href="https://linkedin.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="social-link"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span>LinkedIn</span>
      </a>

      <div class="social-divider"></div>

      <!-- Root-me -->
      <a
        href="https://www.root-me.org/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Root-me"
        class="social-link"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        <span>Root-me</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1.0625rem;
    padding: 0.875rem 2.25rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 32px rgba(56, 189, 248, 0.25);
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .contact-card:hover {
    transform: translateY(-3px);
  }

  .contact-icon-wrap {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(56, 189, 248, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgb(148 163 184);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease, transform 0.2s ease;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
  }

  .social-link:hover {
    color: #38bdf8;
    transform: translateY(-2px);
  }

  .social-divider {
    width: 1px;
    height: 1.5rem;
    background: rgba(148, 163, 184, 0.2);
  }
</style>
