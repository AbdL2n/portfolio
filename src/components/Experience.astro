---
// Experience.astro

const jobs = [
  {
    logo: "/images/logos/academie.png",
    companyKey: "exp_job_0_company",
    companyDefault: "Académie d'Amiens",
    roleKey: "exp_job_0_role",
    roleDefault: "Mathematics &amp; CS Teacher",
    periodKey: "exp_job_0_period",
    periodDefault: "03/2026 – 05/2026",
    locationKey: "exp_job_0_location",
    locationDefault: "Saint-Quentin, France",
    descKey: "exp_job_0_desc",
    descDefault: "Contractual mathematics teacher",
  },
  {
    logo: "/images/logos/acadomia.png",
    companyKey: "exp_job_2_company",
    companyDefault: "Acadomia",
    roleKey: "exp_job_2_role",
    roleDefault: "Tutor",
    periodKey: "exp_job_2_period",
    periodDefault: "2025 – 2026",
    locationKey: "exp_job_2_location",
    locationDefault: "France",
    descKey: "exp_job_2_desc",
    descDefault: "Tutor in mathematics, physics, and chemistry",
  },
  {
    logo: "/images/logos/completude.png",
    companyKey: "exp_job_1_company",
    companyDefault: "Complétude",
    roleKey: "exp_job_1_role",
    roleDefault: "Tutor",
    periodKey: "exp_job_1_period",
    periodDefault: "2022 – 2025",
    locationKey: "exp_job_1_location",
    locationDefault: "France",
    descKey: "exp_job_1_desc",
    descDefault: "Tutor in mathematics, physics, and chemistry",
  },
  {
    logo: "/images/logos/pg.png",
    companyKey: "exp_job_3_company",
    companyDefault: "Procter & Gamble",
    roleKey: "exp_job_3_role",
    roleDefault: "Software Engineer",
    periodKey: "exp_job_3_period",
    periodDefault: "04/2025 – 10/2025",
    locationKey: "exp_job_3_location",
    locationDefault: "Amiens, France",
    descKey: "exp_job_3_desc",
    descDefault: "<ul class=\"list-disc list-outside pl-4 space-y-1\"><li>Secured infrastructure by migrating critical applications to DMZ, reducing attack surface by 20%.</li><li>Complete full stack development of a factory application in Python (Flask, restAPI, DevOps, Azure).</li><li>Reduction by 2 in operator execution time, 50% savings in costs related to losses on forward lines.</li></ul>",
  },
  {
    logo: "/images/logos/pg.png",
    companyKey: "exp_job_4_company",
    companyDefault: "Procter & Gamble",
    roleKey: "exp_job_4_role",
    roleDefault: "IT factory digitalization Internship",
    periodKey: "exp_job_4_period",
    periodDefault: "06/2023 – 08/2023",
    locationKey: "exp_job_4_location",
    locationDefault: "Amiens, France",
    descKey: "exp_job_4_desc",
    descDefault: "<ul class=\"list-disc list-outside pl-4 space-y-1\"><li>Continuous Improvement: Power Platform Factory app rebuilt making the process 3 times faster.</li></ul>",
  },
];
---

<section id="experience" class="py-24 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 right-1/4 w-80 h-80 rounded-full bg-indigo-500/5 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-64 h-64 rounded-full bg-sky-500/5 blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="section-badge" data-i18n="exp_badge">Experience</span>
      <h2 class="text-4xl md:text-5xl font-bold mt-4 mb-4 gradient-text" data-i18n="exp_title">
        Professional Journey
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="exp_subtitle">
        Real-world experience in engineering, education, and technology.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="timeline-line"></div>

      <div class="space-y-12">
        {jobs.map((job, idx) => (
          <div class={`relative flex gap-6 reveal ${idx % 2 === 0 ? "reveal-left" : ""} reveal-delay-${Math.min(idx + 1, 4)}`}>
            <!-- Timeline dot -->
            <div class="timeline-dot-wrapper">
              <div class="timeline-dot"></div>
            </div>

            <!-- Logo -->
            <div class="flex-shrink-0 mt-1">
              <div class="logo-placeholder w-12 h-12 rounded-xl overflow-hidden">
                <img
                  src={job.logo}
                  alt=""
                  class="w-full h-full object-contain"
                  onerror="this.style.display='none'; this.parentElement.classList.add('logo-missing')"
                />
              </div>
            </div>

            <!-- Content -->
            <div class="card flex-1 p-6 hover:border-sky-500/40 transition-colors duration-300">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                <div>
                  <h3
                    class="text-xl font-bold text-white"
                    data-i18n={job.companyKey}
                    set:html={job.companyDefault}
                  />
                  <p
                    class="text-sky-400 font-medium mt-0.5"
                    data-i18n={job.roleKey}
                    set:html={job.roleDefault}
                  />
                </div>
                <div class="text-right flex-shrink-0">
                  <span class="tag text-xs" data-i18n={job.periodKey}>
                    {job.periodDefault}
                  </span>
                  <p class="text-slate-500 text-xs mt-1.5 flex items-center gap-1 justify-end" data-i18n={job.locationKey}>
                    <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    {job.locationDefault}
                  </p>
                </div>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed" data-i18n={job.descKey}>
                {job.descDefault}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-line {
    position: absolute;
    left: 4.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgb(56 189 248 / 0.3) 10%,
      rgb(129 140 248 / 0.3) 50%,
      rgb(56 189 248 / 0.3) 90%,
      transparent
    );
  }

  .timeline-dot-wrapper {
    position: absolute;
    left: 4.1rem;
    top: 1.5rem;
    z-index: 10;
  }

  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: linear-gradient(135deg, #38bdf8, #818cf8);
    box-shadow: 0 0 12px rgba(56, 189, 248, 0.6);
  }

  .logo-placeholder {
    background: #ffffff;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
  }

  .logo-placeholder.logo-missing::before {
    content: "?";
    color: rgb(56 189 248 / 0.4);
    font-size: 1.25rem;
    font-weight: bold;
  }
</style>
